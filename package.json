{
  "name": "@cfpb/design-system-react",
  "license": "MIT",
  "version": "1.0.4",
  "repository": {
    "type": "git",
    "url": "https://github.com/cfpb/design-system-react.git"
  },
  "author": {
    "name": "Consumer Financial Protection Bureau",
    "email": "tech@cfpb.gov",
    "url": "https://cfpb.github.io/"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./index.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=26.x"
  },
  "scripts": {
    "build": "vite build",
    "prepack": "vite build",
    "prepare": "husky",
    "commit": "cz",
    "dev": "vite --open",
    "preview": "vite preview",
    "preview:test": "start-server-and-test preview http://localhost:4173",
    "test": "vitest",
    "test-report": "open coverage/lcov-report/index.html",
    "test:ci": "vitest run",
    "format": "prettier -uw --cache --ignore-path .gitignore .",
    "lint": "scripts/lint.sh",
    "validate": "run-p lint build test:ci",
    "start": "yarn storybook",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o dist-storybook",
    "chromatic": "chromatic --storybook-build-dir dist-storybook --only-changed"
  },
  "dependencies": {
    "react-select": "^5.10.2"
  },
  "peerDependencies": {
    "@cfpb/cfpb-design-system": "5.5.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router": "^7.15.1"
  },
  "devDependencies": {
    "@cfpb/browserslist-config": "^0.0.6",
    "@cfpb/cfpb-design-system": "5.5.1",
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/source-sans-3": "5.2.9",
    "@nabla/vite-plugin-eslint": "^3.0.1",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-links": "^10.4.1",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/css-mediaquery": "0.1.4",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/testing-library__jest-dom": "6.0.0",
    "@typescript-eslint/eslint-plugin": "8.60.0",
    "@typescript-eslint/parser": "8.60.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser-playwright": "4.1.7",
    "@vitest/coverage-istanbul": "^4.1.7",
    "astring": "^1.9.0",
    "autoprefixer": "10.5.0",
    "chromatic": "^17.1.0",
    "classnames": "^2.5.1",
    "commitizen": "4.3.1",
    "css-mediaquery": "0.1.2",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "^10.4.1",
    "eslint-plugin-testing-library": "7.16.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "husky": "9.1.7",
    "jest-matchmedia-mock": "1.1.0",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.5",
    "lit": "^3.3.3",
    "npm-run-all": "4.1.5",
    "playwright": "^1.60.0",
    "postcss": "8.5.15",
    "prettier": "3.8.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router": "^7.16.0",
    "rollup-plugin-jsx-remove-attributes": "^3.1.2",
    "sass": "^1.100.0",
    "start-server-and-test": "3.0.5",
    "storybook": "^10.4.1",
    "storybook-addon-tag-badges": "^3.1.0",
    "storybook-font-inspector": "^1.1.7",
    "stylelint": "^17.12.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.1",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-svgr": "^5.2.0",
    "vite-plugin-turbosnap": "^1.0.3",
    "vitest": "^4.1.7"
  },
  "resolutions": {
    "braces": "3.0.3",
    "socks": ">=2.8.3",
    "ws": ">=8.18.1",
    "rollup": ">=2.79.2",
    "form-data": ">=4.0.4",
    "glob": ">=11.1.0"
  },
  "prettier": {
    "singleQuote": true,
    "jsxSingleQuote": true
  },
  "browserslist": "> 0.2% in @cfpb/browserslist-config stats",
  "lint-staged": {
    "*": "prettier -uw --cache",
    "*.css": "stylelint --cache --fix",
    "*.{ts,tsx}": [
      "eslint --cache --fix",
      "vitest related --run --coverage=false"
    ]
  },
  "type": "module",
  "packageManager": "yarn@4.15.0"
}
