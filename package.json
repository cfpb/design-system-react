{
  "name": "@cfpb/design-system-react",
  "license": "MIT",
  "version": "0.0.16",
  "repository": {
    "type": "git",
    "url": "https://github.com/cfpb/design-system-react.git"
  },
  "author": {
    "name": "Consumer Financial Protection Bureau",
    "email": "tech@cfpb.gov",
    "url": "https://cfpb.github.io/"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./index.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "vite build",
    "prepack": "vite build",
    "commit": "cz",
    "dev": "vite --open",
    "preview": "vite preview",
    "preview:test": "start-server-and-test preview http://localhost:4173",
    "test": "vitest",
    "test-report": "open coverage/lcov-report/index.html",
    "test:ci": "vitest run",
    "format": "prettier -uw --cache --ignore-path .gitignore .",
    "lint": "scripts/lint.sh",
    "validate": "run-p lint test:ci test:e2e:headless",
    "start": "yarn storybook",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o dist-storybook",
    "chromatic": "chromatic --storybook-build-dir dist-storybook --only-changed"
  },
  "dependencies": {
    "react-select": "^5.10.2"
  },
  "peerDependencies": {
    "@cfpb/cfpb-design-system": "4.4.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-router": "^7.13.0"
  },
  "devDependencies": {
    "@cfpb/browserslist-config": "^0.0.6",
    "@cfpb/cfpb-design-system": "4.4.0",
    "@chromatic-com/storybook": "^5.0.1",
    "@eslint/js": "^9.39.3",
    "@nabla/vite-plugin-eslint": "^2.0.6",
    "@storybook/addon-a11y": "^10.2.11",
    "@storybook/addon-docs": "^10.2.11",
    "@storybook/addon-links": "^10.2.11",
    "@storybook/addon-vitest": "^10.2.11",
    "@storybook/react-vite": "^10.2.11",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/css-mediaquery": "0.1.4",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/testing-library__jest-dom": "6.0.0",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser-playwright": "4.0.18",
    "@vitest/coverage-istanbul": "^4.0.18",
    "astring": "^1.9.0",
    "autoprefixer": "10.4.24",
    "chromatic": "^15.1.1",
    "classnames": "^2.5.1",
    "commitizen": "4.3.1",
    "css-mediaquery": "0.1.2",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "9.39.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^10.2.11",
    "eslint-plugin-testing-library": "7.16.0",
    "eslint-plugin-unicorn": "^62.0.0",
    "globals": "^17.3.0",
    "husky": "9.1.7",
    "jest-matchmedia-mock": "1.1.0",
    "jsdom": "28.1.0",
    "lint-staged": "16.2.7",
    "npm-run-all": "4.1.5",
    "playwright": "^1.58.2",
    "postcss": "8.5.6",
    "prettier": "3.8.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router": "^7.13.1",
    "rollup-plugin-jsx-remove-attributes": "^3.1.2",
    "sass": "^1.97.3",
    "start-server-and-test": "2.1.3",
    "storybook": "^10.2.11",
    "stylelint": "^17.3.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-svgr": "^4.5.0",
    "vite-plugin-turbosnap": "^1.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "resolutions": {
    "braces": "3.0.3",
    "socks": ">=2.8.3",
    "ws": ">=8.18.1",
    "rollup": ">=2.79.2",
    "form-data": ">=4.0.4",
    "glob": ">=11.1.0"
  },
  "prettier": {
    "singleQuote": true,
    "jsxSingleQuote": true
  },
  "browserslist": "> 0.2% in @cfpb/browserslist-config stats",
  "lint-staged": {
    "*": "prettier -uw --cache",
    "*.css": "stylelint --cache --fix",
    "*.{ts,tsx}": [
      "eslint --cache --fix",
      "vitest related --run --coverage=false"
    ]
  },
  "type": "module",
  "packageManager": "yarn@4.12.0"
}
